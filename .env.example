# PlayMore configuration — copy to .env and edit
# All values shown are defaults; uncomment and edit only what you need.

# === Core ===
# PLAYMORE_PORT=8080
# PLAYMORE_DATA=data
# PLAYMORE_BASE_URL=https://playmore.example.com

# === HTTPS — pick ONE approach ===

# Option 1: Auto Let's Encrypt (needs ports 80 + 443 reachable)
# PLAYMORE_AUTO_TLS=true
# PLAYMORE_DOMAIN=playmore.example.com

# Option 2: Manual cert files
# PLAYMORE_TLS_CERT=/etc/letsencrypt/live/playmore/fullchain.pem
# PLAYMORE_TLS_KEY=/etc/letsencrypt/live/playmore/privkey.pem

# Option 3: Reverse proxy (Caddy/nginx) — leave TLS unset, set this:
# PLAYMORE_BEHIND_TLS_PROXY=true
# PLAYMORE_TRUSTED_PROXIES=127.0.0.1/32

# === Email (SMTP) — optional but recommended ===
# When set, registration sends verification email and uploads/reviews
# require verified email.
# PLAYMORE_SMTP_HOST=smtp.example.com
# PLAYMORE_SMTP_PORT=587
# PLAYMORE_SMTP_USER=noreply@example.com
# PLAYMORE_SMTP_PASS=your-smtp-password
# PLAYMORE_SMTP_FROM=PlayMore <noreply@example.com>

# === Game origin isolation (defense-in-depth) ===
# When set, uploaded games are loaded from this subdomain instead of
# the main domain. Iframe sandbox already isolates games; this adds
# origin separation. Requires DNS/wildcard cert pointing here.
# PLAYMORE_GAMES_DOMAIN=games.example.com

# === Analytics — optional ===
# PLAYMORE_GOATCOUNTER=https://yourname.goatcounter.com
